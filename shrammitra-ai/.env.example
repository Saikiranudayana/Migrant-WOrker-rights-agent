# =============================================================================
# ShramMitra AI — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=ShramMitra AI
APP_ENV=development          # development | staging | production
APP_DEBUG=false
APP_PORT=8000
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# Secret key for JWT signing (generate: openssl rand -hex 32)
SECRET_KEY=change-me-to-a-strong-random-secret-key-at-least-32-chars

# Admin API key (hashed with bcrypt in production)
ADMIN_API_KEY=change-me-admin-api-key

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://your-domain.com

# -----------------------------------------------------------------------------
# Database — PostgreSQL
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://shrammitra:password@localhost:5432/shrammitra
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# -----------------------------------------------------------------------------
# Cache — Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
SESSION_TTL_SECONDS=3600     # 1 hour session window

# -----------------------------------------------------------------------------
# AWS Configuration
# -----------------------------------------------------------------------------
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# For EC2 with IAM role, leave ACCESS_KEY_ID and SECRET_ACCESS_KEY empty
# and AWS SDK will use instance profile automatically.

# Amazon Bedrock
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_REGION=us-east-1
BEDROCK_MAX_TOKENS=2048
BEDROCK_TEMPERATURE=0.1

# Amazon S3
S3_BUCKET_DOCUMENTS=shrammitra-documents-prod
S3_BUCKET_AUDIO=shrammitra-audio-prod

# Amazon Transcribe (Speech-to-Text)
TRANSCRIBE_REGION=ap-south-1
TRANSCRIBE_OUTPUT_BUCKET=shrammitra-audio-prod

# Amazon Polly (Text-to-Speech)
POLLY_REGION=ap-south-1

# AWS Secrets Manager (in production, secrets are fetched from here)
USE_SECRETS_MANAGER=false
SECRETS_MANAGER_PREFIX=shrammitra/prod/

# -----------------------------------------------------------------------------
# Elasticsearch
# -----------------------------------------------------------------------------
ELASTICSEARCH_URL=https://YOUR_CLUSTER_ID.ap-south-1.aws.elastic.cloud:9243
ELASTICSEARCH_API_KEY=YOUR_ELASTICSEARCH_API_KEY_HERE
ELASTICSEARCH_INDEX_NAME=shrammitra_labour_docs_v1
ELASTICSEARCH_INDEX_ALIAS=shrammitra_labour_docs

# Jina Embeddings (via Elastic Inference Service)
JINA_EMBEDDING_MODEL=jina-embeddings-v3
EMBEDDING_DIMENSION=1024

# RAG Configuration
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7
RAG_MAX_CONTEXT_TOKENS=3000

# -----------------------------------------------------------------------------
# WhatsApp Business API (Meta Cloud API)
# -----------------------------------------------------------------------------
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
WHATSAPP_ACCESS_TOKEN=your-permanent-access-token
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token    # Any random string you choose
WHATSAPP_API_VERSION=v19.0
WHATSAPP_API_BASE_URL=https://graph.facebook.com

# App Secret for webhook signature verification
WHATSAPP_APP_SECRET=your-app-secret

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_PER_MINUTE=30        # Per phone number
RATE_LIMIT_BURST=10             # Burst allowance
GLOBAL_RATE_LIMIT_PER_MINUTE=1000

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
CLOUDWATCH_NAMESPACE=ShramMitra/Application
ENABLE_METRICS=true
SENTRY_DSN=                     # Optional: Sentry error tracking

# -----------------------------------------------------------------------------
# Frontend (Next.js)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=ShramMitra AI Admin
